{
  "rules": {
    "public": {
      "rooms": {
        "$roomId": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    "secret": {
      "rooms": {
        "$roomId": {
          ".read": "auth != null && (data.child('stUid').val() === auth.uid || data.child('players').child(auth.uid).child('character').val() === 'spy')",
          ".write": "auth != null && (!data.exists() || data.child('stUid').val() === auth.uid)",
          
          "players": {
            "$uid": {
              ".read": "auth != null && $uid === auth.uid",
              ".write": "auth != null && data.parent().parent().child('stUid').val() === auth.uid"
            }
          },
          "nightActions": {
            "$uid": {
              ".write": "auth != null && $uid === auth.uid"
            }
          }
        }
      }
    }
  }
}